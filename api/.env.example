# =============================================================================
# Cortex API — environment template
# Copy to .env and fill values for local dev. NEVER commit .env.
#
# Prefix convention: every BaseSettings class uses CORE_<DOMAIN>_<KEY>, matching
# the env vars projected by the helm chart from cortex-rds-credentials and the
# AWS Secrets Manager-backed K8s Secrets.
# =============================================================================

# --- FastAPI ---
CORE_FASTAPI_PORT=8000
CORE_FASTAPI_DEBUG=true
CORE_FASTAPI_APP_VERSION=0.1.0
CORE_FASTAPI_CORS_ORIGINS=http://localhost:3000

# --- Logging ---
CORE_LOG_LEVEL=INFO
CORE_LOG_FORMAT=json

# --- Database (AWS RDS PostgreSQL in prod; local Postgres for dev) ---
# DSN is assembled at runtime from these five components by DatabaseConfig.url —
# this matches the helm chart's cortex-rds-credentials projection.
# Lakebase was the original plan but isn't in ap-northeast-1 yet, so RDS for now.
CORE_DB_HOST=localhost
CORE_DB_PORT=5433
CORE_DB_USERNAME=cortex
CORE_DB_PASSWORD=cortex
CORE_DB_NAME=cortex
CORE_DB_POOL_SIZE=10
CORE_DB_POOL_PRE_PING=true

# --- Redis ---
CORE_REDIS_URL=redis://localhost:6379/0
CORE_REDIS_DEFAULT_TTL=300

# --- Auth (JWT signed by NextAuth, verified here) ---
CORE_AUTH_NEXTAUTH_SECRET=change-me-to-a-long-random-string
CORE_AUTH_JWT_ALGORITHM=HS256
CORE_AUTH_JWT_AUDIENCE=cortex-api
CORE_AUTH_JWT_ISSUER=cortex-web

# --- Databricks SQL Warehouse (analytical reads) ---
CORE_DATABRICKS_HOST=
CORE_DATABRICKS_HTTP_PATH=
CORE_DATABRICKS_CLIENT_ID=
CORE_DATABRICKS_CLIENT_SECRET=

# --- Databricks Vector Search ---
CORE_VECTOR_SEARCH_ENDPOINT=
CORE_VECTOR_SEARCH_INDEX=

# --- SP-3a brand analyze (server-managed LLM extraction) ---
# REQUIRED for the onboarding steps 1&2 real analyze pipeline. In
# UAT/prod these come from the Helm chart (cortex secret); set locally to
# run the real extraction. Without CORTEX_ANALYZE_API_KEY the analyze job
# fails.
# NOTE: these BaseSettings read OS env only (no env_file), so run uvicorn
# with the env loaded — `uvicorn cortex_api.main:app --env-file .env` —
# or every config silently falls back to its default.
CORTEX_ANALYZE_PROVIDER_KIND=claude
CORTEX_ANALYZE_MODEL=claude-opus-4-7
CORTEX_ANALYZE_TIER=lite
CORTEX_ANALYZE_API_KEY=
