    "@tanstack/react-query": "^5.59.0",
    "@tanstack/react-query-devtools": "^5.59.0",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.0",
    "jose": "^6.2.3",
    "lucide-react": "^0.460.0",
    "next": "^16.0.0",
    "next-auth": "^5.0.0-beta.20",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
