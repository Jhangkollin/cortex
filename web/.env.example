# =============================================================================
# Cortex web — environment template
# =============================================================================

# API
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# NextAuth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=change-me-to-a-long-random-string

# Google OAuth (https://console.cloud.google.com/apis/credentials)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Restrict sign-in to a specific Google Workspace domain
NEXTAUTH_ALLOWED_DOMAIN=mlytics.com

# Dev-only — set in .env.local for local development without Google OAuth.
# When "true", mock-session-provider seeds DEMO_BRAND_USER + brand persona +
# onboardingComplete=true on first paint, and the projection trusts that
# seed instead of NextAuth's "unauthenticated" verdict. Lets you reach
# protected routes (/brand/dashboard etc.) without a real OAuth round-trip.
# NEVER set this in UAT or PROD — checked at module scope so it inlines
# and tree-shakes out of production bundles.
NEXT_PUBLIC_DEV_BYPASS_AUTH=false
